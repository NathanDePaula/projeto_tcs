{
  "openapi": "3.0.4",
  "info": {
    "title": "Instagram API - Gerenciamento de Usuários",
    "description": "API REST de gerenciamento de usuários com autenticação JWT. Padrão de resposta: { status, codigo, mensagem, dados }.",
    "version": "1.0.1"
  },
  "servers": [
    {
      "url": "http://localhost:8082",
      "description": "API - Instagram"
    }
  ],
  "tags": [
    {
      "name": "usuarios",
      "description": "Operações relacionadas ao usuário"
    },
    {
      "name": "login",
      "description": "Operações de autenticação (login, logout)"
    },
    {
      "name":"posts",
      "description": "Operações relacionadas a posts"
    }
  ],
  "paths": {
    
    "/usuarios/{id-usuario}/posts": {
      "get": {
        "tags": [
          "posts"
        ],
        "summary": "Listar posts",
        "description": "Retorna a lista de posts cadastrados.",
        "operationId": "listarPosts",
        "responses": {
          "200": {
            "description": "Posts listados com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListagemPostsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Token inválido ou expirado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          },
          "404": {
            "description": "Nenhum post encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }, "post": {
        "tags": [
          "posts"
        ],
        "summary": "Criar post",
        "description": "Cria um novo post para o usuário especificado.",
        "operationId": "criarPost",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CriaçãoPostRequest"
              },
              "example": {
                "imagem": "post1.jpg",
                "legenda": "Meu novo post!"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Post criado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Sucesso"
                }
              }
            }
          },
          "400": {
            "description": "Dados incompletos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          },
          "401": {
            "description": "Token inválido ou expirado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          },
          "404": {
            "description": "Usuário não encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          }
        },"security": [
          {
            "BearerAuth": []
          }
        ]
      }
    
    },
    "/usuarios/{id-usuario}/posts/{id-post}": {
      "get": {
        "tags": ["posts"],
        "summary": "Obter Post por ID",
        "description": "Retorna os detalhes de um post específico.",
        "operationId": "obterPostPorId",
        "parameters": [
          {
            "name": "id-usuario",
            "in": "path",
            "description": "ID do usuário dono do post",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id-post",
            "in": "path",
            "description": "ID do post",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Post recuperado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PadraoResposta"
                }
              }
            }
          },
          "404": {
            "description": "Post não encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      },
      "post":{
        "tags": ["posts"],
        "summary": "Curtir Post",
        "description": "Inclui uma curtida no post especificado.",
        "operationId": "curtirPost",
        "requestBody": {
          "description": "Dados do post a ser criado",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CurtidaResponse"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Curtida adicionada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Sucesso"
                }
              }
            }
          },
          "400": {
            "description": "Dados inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          },
          "401": {
            "description": "Token inválido ou expirado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      },
      "patch": {
        "tags": ["posts"],
        "summary": "Atualizar post",
        "description": "Atualiza completamente os dados de um post pelo ID.",
        "operationId": "atualizarPost",
        "parameters": [
          {
            "name": "id-usuario",
            "in": "path",
            "description": "ID do usuário dono do post",
            "required": true,
            "schema": {
              "type": "string"
            }
          }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AtualizacaoPostRequest" }
              }},
          "required": true
      }, "responses": {
      "200":{
          "description": "Post atualizado com sucesso",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Sucesso"
              }
            }
          }
        },
        "400": {
          "description": "Dados incompletos",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ErroResponse"
              }
            }
          }
        },
        "401": {
          "description": "Token inválido ou expirado",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ErroResponse"
              }
            }
          }
        },
        "404": {
          "description": "Post não encontrado",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ErroResponse"
              }
      }
      }
    }},
      "security": [
        {
          "BearerAuth": []
        }
      ]
    },
    "delete": {
      "tags": [
        "posts"
      ],
      "summary": "Deletar post",
      "description": "Remove um post do sistema pelo ID.",
      "operationId": "deletarPost",
      "parameters": [
        {
          "name": "id-post",
          "in": "path",
          "description": "ID do post",
          "required": true,
          "schema": {
            "type": "string"
          }
        },{
          "name": "id-usuario",
          "in": "path",
          "description": "ID do usuário dono do post",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Post deletado com sucesso",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Sucesso"
              }
            }
          }
        },
        "401": {
          "description": "Token inválido ou expirado",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ErroResponse"
              }
            }
          }
        },
        "403": {
          "description": "Acesso negado",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ErroResponse"
              }
            }
          }
        },
        "404": {
          "description": "Post não encontrado",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ErroResponse"
              }
            }
          }
        }
      },
      "security": [
        {
          "BearerAuth": []
        }
      ]
    }
    },
    "/usuarios/login": {
      "post": {
        "tags": [
          "login"
        ],
        "summary": "Login do usuário",
        "description": "Autentica o usuário com usuário e senha, retornando token JWT.",
        "operationId": "loginUsuario",
        "requestBody": {
          "description": "Credenciais de acesso",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "usuario": "joao",
                "senha": "123"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Login realizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Dados incompletos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          },
          "401": {
            "description": "Credenciais inválidas",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          }
        }
      }
    },
    "/usuarios/logout": {
      "post": {
        "tags": [
          "login"
        ],
        "summary": "Logout do usuário",
        "description": "Encerrando a sessão do usuário e revoga acesso token JWT.",
        "operationId": "logoutUsuario",
        "responses": {
          "200": {
            "description": "Logout realizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SucessoSimples"
                }
              }
            }
          },
          "400": {
            "description": "Token não informado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          },
          "401": {
            "description": "Token inválido ou expirado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/usuarios": {
      "get": {
        "tags": [
          "usuarios"
        ],
        "summary": "Listar usuários",
        "description": "Retorna a lista de usuários cadastrados.",
        "operationId": "listarUsuarios",
        "responses": {
          "200": {
            "description": "Usuários listados com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListagemResponse"
                }
              }
            }
          },
          "401": {
            "description": "Token inválido ou expirado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          },
          "404": {
            "description": "Nenhum usuário encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      },
      "post": {
        "tags": [
          "usuarios"
        ],
        "summary": "Cadastrar usuário",
        "description": "Cria um novo usuário no sistema.",
        "operationId": "cadastrarUsuario",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CadastroRequest"
              },
              "example": {
                "nome": "João",
                "email": "j@j.com",
                "usuario": "joao",
                "senha": "123"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Usuário cadastrado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CadastroResponse"
                }
              }
            }
          },
          "400": {
            "description": "Dados incompletos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          },
          "405": {
            "description": "Dados inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          },
          "409": {
            "description": "Usuário já cadastrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          }
        }
      }
    },
    "/usuarios/{id}": {
      "get": {
        "tags": [
          "usuarios"
        ],
        "summary": "Obter dados de um usuário",
        "description": "Retorna os detalhes de um usuário específico baseado no ID fornecido.",
        "operationId": "obterUsuarioPorId",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID do usuário a ser recuperado",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Usuário encontrado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UsuarioUnicoResponse"
                }
              }
            }
          },
          "401": {
            "description": "Token inválido ou expirado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          },
          "403": {
            "description": "Acesso negado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          },
          "404": {
            "description": "Usuário não encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      },
      "patch": {
        "tags": [
          "usuarios"
        ],
        "summary": "Atualizar usuário",
        "description": "Atualiza completamente os dados de um usuário pelo ID.",
        "operationId": "atualizarUsuario",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID do usuário",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AtualizacaoRequest"
              },
              "example": {
                "nome": "João",
                "email": "j@j.com",
                "usuario": "joao"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Usuário atualizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AtualizacaoResponse"
                }
              }
            }
          },
          "400": {
            "description": "Dados incompletos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          },
          "401": {
            "description": "Token inválido ou expirado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          },
          "404": {
            "description": "Usuário já existe",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "usuarios"
        ],
        "summary": "Deletar usuário",
        "description": "Remove um usuário do sistema pelo ID.",
        "operationId": "deletarUsuario",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID do usuário",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Usuário deletado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SucessoSimples"
                }
              }
            }
          },
          "401": {
            "description": "Token inválido ou expirado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          },
          "403": {
            "description": "Acesso negado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErroResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "AtualizacaoPostRequest": {
        "type": "object",
        "properties": {
          "legenda": {
            "type": "string",
            "example": "Meu post atualizado!",
            "maxLength": 200,
            "description": "Texto que acompanha a imagem do post",
            "minLength": 5

          }
        },
        "required": [
          "legenda"
        ]
      },
      "CurtidaResponse": {
        "type": "object",
        "properties": {
          "id_usuario": {
            "type": "string",
            "example": "1"
          },
          "id_post": {
            "type": "string",
            "example": "1"
          }
        },
        "required": [
          "id_usuario",
          "id_post"
        ]
      },
      "Sucesso":{
        "example": {
          "status": "sucesso",
          "codigo": "OPERACAO_SUCESSO",
          "mensagem": "Operação realizada com sucesso"
        },
        "allOf": [
          {
            "$ref": "#/components/schemas/PadraoResposta"
          }
        ] 
      },
      "CriaçãoPostRequest": {
        "type": "object",
        "properties": {
          "imagem": {
            "type": "string",
            "description": "string Base64"
          },
          "legenda": {
            "type": "string",
            "example": "Meu novo post!",
            "maxLength": 200,
            "description": "Texto que acompanha a imagem do post",
            "minLength": 5

          }
        },
        "required": [
          "imagem",
          "legenda"
        ]
      },
      "ListagemPostsResponse": {
        "example": {
          "status": "sucesso",
          "codigo": "LISTAGEM_POSTS_SUCESSO",
          "mensagem": "Posts listados com sucesso",
          "posts": [
              {
                "id": "1",
                "conteudo": "Meu primeiro post!",
                "imagem": "post1.jpg(BASE64)",
                "curtidas":"10"
              }
            ]
          
        },
        "allOf": [
          {
            "$ref": "#/components/schemas/PadraoResposta"
          }
        ]
      },
      "LogoutRequest": {
        "type": "object",
        "properties": {
          "Token": {
            "type": "string",
            "example": "eyJhbGci..."
          }
        }
      },
      "PadraoResposta": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "sucesso",
              "erro"
            ]
          },
          "codigo": {
            "type": "string",
            "example": "CODIGO_PADRAO"
          },
          "mensagem": {
            "type": "string",
            "example": "Mensagem de retorno"
          }
        }
      },
      "ErroResponse": {
        "example": {
          "status": "erro",
          "codigo": "CODIGO_ERRO",
          "mensagem": "Descrição do erro"
        },
        "allOf": [
          {
            "$ref": "#/components/schemas/PadraoResposta"
          }
        ]
      },
      "SucessoSimples": {
        "example": {
          "status": "sucesso",
          "codigo": "OPERACAO_SUCESSO",
          "mensagem": "Operação realizada com sucesso",
          "dados": {}
        },
        "allOf": [
          {
            "$ref": "#/components/schemas/PadraoResposta"
          }
        ]
      },
      "LoginRequest": {
        "required": [
          "senha",
          "usuario"
        ],
        "type": "object",
        "properties": {
          "usuario": {
            "type": "string",
            "example": "joao"
          },
          "senha": {
            "type": "string",
            "format": "password",
            "example": "123"
          }
        }
      },
      "LoginResponse": {
        "example": {
          "status": "sucesso",
          "codigo": "LOGIN_SUCESSO",
          "mensagem": "Login realizado com sucesso",
          "dados": {
            "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "usuario": {
              "id": "1",
              "nome": "João",
              "email": "j@j.com"
            }
          }
        },
        "allOf": [
          {
            "$ref": "#/components/schemas/PadraoResposta"
          }
        ]
      },
      "CadastroRequest": {
        "required": [
          "email",
          "nome",
          "senha",
          "usuario"
        ],
        "type": "object",
        "properties": {
          "nome": {
            "type": "string",
            "example": "João da Silva"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "j@j.com"
          },
