### Variáveis de Ambiente
@baseUrl = http://localhost:8080
@usuarioSucesso = joao_updated
@senhaSucesso = nova_senha_123

### 1. Login com Sucesso
# Deve retornar 200 OK com token e dados do usuário
POST {{baseUrl}}/usuarios/login
Content-Type: application/json

{
    "usuario": "{{usuarioSucesso}}",
    "senha": "{{senhaSucesso}}"
}

### 2. Erro - Dados Incompletos (Sem Usuário)
# Deve retornar 400 Bad Request (dados_incompletos)
POST {{baseUrl}}/usuarios/login
Content-Type: application/json

{
    "senha": "{{senhaSucesso}}"
}

### 3. Erro - Dados Incompletos (Sem Senha)
# Deve retornar 400 Bad Request (dados_incompletos)
POST {{baseUrl}}/usuarios/login
Content-Type: application/json

{
    "usuario": "{{usuarioSucesso}}"
}

### 4. Erro - Usuário muito curto (Validação Jakarta)
# Deve retornar 400 Bad Request (dados_invalidos)
POST {{baseUrl}}/usuarios/login
Content-Type: application/json

{
    "usuario": "jo",
    "senha": "{{senhaSucesso}}"
}

### 5. Erro - Usuário com caracteres inválidos (Validação Jakarta)
# Deve retornar 400 Bad Request (dados_invalidos)
POST {{baseUrl}}/usuarios/login
Content-Type: application/json

{
    "usuario": "joao@123",
    "senha": "{{senhaSucesso}}"
}

### 6. Erro - Senha muito curta (Validação Jakarta)
# Deve retornar 400 Bad Request (dados_invalidos)
POST {{baseUrl}}/usuarios/login
Content-Type: application/json

{
    "usuario": "{{usuarioSucesso}}",
    "senha": "123"
}

### 7. Erro - Credenciais Inválidas (Senha errada)
# Deve retornar 401 Unauthorized (credenciais_invalidas)
POST {{baseUrl}}/usuarios/login
Content-Type: application/json

{
    "usuario": "{{usuarioSucesso}}",
    "senha": "senha_errada_123"
}

### 8. Erro - Credenciais Inválidas (Usuário não existe)
# Deve retornar 401 Unauthorized (credenciais_invalidas)
POST {{baseUrl}}/usuarios/login
Content-Type: application/json

{
    "usuario": "usuario_inexistente",
    "senha": "{{senhaSucesso}}"
}
